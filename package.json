{
  "name": "nickygencs17.github.io",
  "version": "1.0.0",
  "description": "Personal site for Nicholas Genco (GitHub Pages). Dev tooling for image optimization and CI checks.",
  "private": true,
  "type": "module",
  "scripts": {
    "optimize:images": "node scripts/optimize-images.mjs",
    "build:social-preview": "node scripts/create-social-preview.mjs",
    "test": "node --test tests/*.test.mjs",
    "lint:html": "html-validate index.html resume.html data/NicholasGenco.resume.html",
    "lint:links": "node scripts/lint-links.mjs",
    "lint": "npm test && npm run lint:html && npm run lint:links"
  },
  "devDependencies": {
    "html-validate": "^8.0.0",
    "linkinator": "^4.0.0"
  },
  "optionalDependencies": {
    "sharp": "^0.33.0"
  }
}
